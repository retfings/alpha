/// Strategy engine and registry
///
/// Core engine for executing strategies and processing signals.

///|
/// Strategy result for a single period
/// Contains the signal generated by the strategy
pub(all) struct StrategyResult {
  /// Trading signal generated by the strategy
  signal : Signal
} derive(ToJson, Show)

///|
/// Strategy engine state
/// Manages capital, positions, and signal history
pub(all) struct StrategyEngine {
  /// Available cash capital
  capital : Float
  /// Current position (number of shares held)
  position : Float
  /// Last observed market price
  last_price : Float
  /// History of all generated signals
  signals : Array[Signal]
  /// History of all strategy results
  results : Array[StrategyResult]
}

///|
/// Create a new strategy engine
pub fn create_strategy_engine(initial_capital : Float) -> StrategyEngine {
  StrategyEngine::{
    capital: initial_capital,
    position: 0.0,
    last_price: 0.0,
    signals: [],
    results: [],
  }
}

///|
/// Process a single bar through the strategy
pub fn process_bar(
  engine : StrategyEngine,
  strategy : Strategy,
  kline : @data.KLine,
  close_history : Array[Float],
) -> StrategyResult {
  let ctx = StrategyContext::{
    capital: engine.capital,
    position: engine.position,
    current_price: kline.close,
    last_signal: engine.signals.last(),
  }

  let signal = (strategy.on_bar)(kline, ctx, close_history)
  StrategyResult::{ signal }
}

///|
/// Get engine statistics
pub fn get_engine_stats(engine : StrategyEngine) -> (Float, Float, Int) {
  (engine.capital, engine.position, engine.signals.length())
}
